# Agora App credentials
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate

# Supabase credentials
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Agora Cloud Recording (REST API credentials - different from app credentials)
AGORA_CUSTOMER_KEY=your_agora_rest_api_customer_key
AGORA_CUSTOMER_SECRET=your_agora_rest_api_customer_secret

# AWS S3 for livestream recordings storage
AWS_ACCESS_KEY=your_aws_access_key_id
AWS_SECRET_KEY=your_aws_secret_access_key
S3_BUCKET_NAME=balagh-livestreams
