{
  "expo": {
    "name": "Bushrann",
    "slug": "Balagh",
    "scheme": "bushrann",
    "deepLinking": true,
    "version": "1.0.0",
    "runtimeVersion": "1.0.0",
    "updates": {
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/your-project-id"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#0a1172"
    },
    "ios": {
      "supportsTablet": true,
      "associatedDomains": ["applinks:bushrann.app"],
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow Bushrann to access your photos to update your profile picture.",
        "NSPhotoLibraryAddUsageDescription": "Allow Bushrann to save videos to your photo library.",
        "NSCameraUsageDescription": "Allow Bushrann to access your camera to take a profile photo."
      }
    },
    "android": {
      "navigationBar": {
        "backgroundColor": "#000000",
        "barStyle": "light-content"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1e4fa3"
      },
      "package": "com.bushrann.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            { "scheme": "https", "host": "bushrann.app", "pathPrefix": "/video" },
            { "scheme": "bushrann", "host": "*" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-video",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Bushrann to use Face ID for sign in"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Bushrann to access your photos to update your profile picture.",
          "cameraPermission": "Allow Bushrann to access your camera to take a profile photo."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Bushrann to access your photos.",
          "savePhotosPermission": "Allow Bushrann to save videos to your photo library.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "expo-web-browser",
      "react-native-video",
      [
        "react-native-fbsdk-next",
        {
          "appID": "YOUR_APP_ID_HERE",
          "clientToken": "YOUR_CLIENT_TOKEN_HERE",
          "displayName": "Bushrann"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "5804d13c-1244-4972-8b7a-083f99fbb885"
      },
      "privacyPolicyUrl": "https://bushrann.app/privacy",
      "supportUrl": "mailto:support@bushrann.app"
    }
  }
}